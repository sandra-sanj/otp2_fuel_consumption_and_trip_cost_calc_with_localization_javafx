<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fuel_and_trip_cost_calc.otp2_fuel_consumption_and_trip_cost_calc_with_localization_javafx.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Add language switch button -->
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="btnEN" text="English" onAction="#onLanguageEnglishButtonClick"/>
        <Button fx:id="btnFR" text="French" onAction="#onLanguageFrenchButtonClick"/>
        <Button fx:id="btnJP" text="Japanese" onAction="#onLanguageJapaneseButtonClick"/>
        <Button fx:id="btnIR" text="Persian" onAction="#onLanguagePersianButtonClick"/>
    </HBox>

    <VBox>
        <Label fx:id="lblDistance"/>
        <TextField fx:id="txtDistance"/>
    </VBox>

    <VBox>
        <Label fx:id="lblConsumption"/>
        <TextField fx:id="txtConsumption"/>
    </VBox>

    <VBox>
        <Label fx:id="lblPrice"/>
        <TextField fx:id="txtPrice"/>
    </VBox>

    <Button fx:id="btnCalculate" onAction="#onCalculateButtonClick"/>
    <Label fx:id="lblResult"/>
</VBox>
